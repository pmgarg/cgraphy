{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pmgarg/cgraphy",
  "description": "Code knowledge graph over MCP: token-budgeted context for AI coding agents.",
  "version": "0.1.2",
  "repository": {
    "url": "https://github.com/pmgarg/cgraphy",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "cgraphy",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "serve",
          "description": "run the MCP server over stdio"
        },
        {
          "type": "positional",
          "value": "{repo_path}",
          "description": "path to the repository to serve",
          "is_required": true
        }
      ]
    }
  ]
}